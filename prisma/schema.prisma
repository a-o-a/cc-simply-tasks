// Phase 1: 도메인 모델 정의.
// - Postgres 이관 대비: id는 cuid, raw SQL 금지, JSON은 문자열로 저장.
// - SQLite는 native enum 미지원이라 enum 컬럼은 모두 String으로 저장.
//   허용 값은 `lib/enums.ts`의 상수 배열이 소스 오브 트루스. zod로 런타임 검증.
// - Postgres 이관 시 String 컬럼을 enum 타입으로 전환 (lib/enums.ts 값과 동일하게).
// - soft delete: deletedAt IS NULL 필터로 목록 조회.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- models ----------

/// role 허용값: lib/enums.ts > MEMBER_ROLES
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  workItems      WorkItem[]
  calendarEvents CalendarEvent[]

  @@index([deletedAt])
}

/// category 허용값: lib/enums.ts > CATEGORIES
/// status   허용값: lib/enums.ts > STATUSES
/// priority 허용값: lib/enums.ts > PRIORITIES
model WorkItem {
  id           String    @id @default(cuid())
  title        String
  description  String?
  category     String    @default("ETC")
  status       String    @default("DRAFT")
  priority     String    @default("NORMAL")
  // 같은 담당자 내 수동 정렬 순서. 낮을수록 상단.
  order        Int       @default(0)
  assigneeId   String?
  startDate    DateTime?
  endDate      DateTime?
  transferDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  assignee TeamMember?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  tickets  WorkTicket[]

  @@index([assigneeId, status])
  @@index([transferDate])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@index([status])
}

model WorkTicket {
  id           String    @id @default(cuid())
  workItemId   String
  systemName   String // "Jira", "Redmine", "GitHub" 등
  ticketNumber String
  ticketUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@unique([workItemId, systemName, ticketNumber])
  @@index([workItemId])
  @@index([ticketNumber])
  @@index([deletedAt])
}

model CalendarEvent {
  id            String    @id @default(cuid())
  title         String
  memberId      String?
  // UTC 저장. allDay=true면 [start, end) 반열림 + 00:00 UTC 정규화(lib/time.ts 담당).
  startDateTime DateTime
  endDateTime   DateTime
  allDay        Boolean   @default(false)
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  member TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([startDateTime, endDateTime])
  @@index([memberId])
  @@index([deletedAt])
}

/// entityType 허용값: lib/enums.ts > AUDIT_ENTITY_TYPES
/// action    허용값: lib/enums.ts > AUDIT_ACTIONS
/// actorType 허용값: lib/enums.ts > ACTOR_TYPES
model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  // 변경된 필드만 담는 diff. JSON.stringify 결과(String).
  // Postgres 이관 시 Json 컬럼으로 교체 가능하게 문자열로 유지.
  beforeJson String?
  afterJson  String?
  actorType  String   @default("ANONYMOUS")
  actorName  String?
  actorIp    String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
}
